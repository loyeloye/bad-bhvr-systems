---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const sorted = services.sort((a, b) => a.data.order - b.data.order);

const iconMap: Record<string, string> = {
  zap: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  brain: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  chart: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  users: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
};
---

<BaseLayout
  title="Services — Automation, AI Integration, Data & CRM"
  description="Process automation, applied AI, business intelligence, and CRM implementation for ambitious companies in Africa and EMEA. One connected operating system."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>One operating system.<br/>Not four disconnected projects.</h1>
      <p class="hero-sub">
        Automation without data is guesswork. Data without automation is a report nobody acts on. AI without either is a toy. We build them as one connected system.
      </p>
    </div>
  </section>

  <!-- Services hairline grid -->
  <section class="services-section">
    <div class="services-grid">
      {sorted.map((service, i) => (
        <article class="service-cell fade" style={`transition-delay:${i * 0.1}s`}>
          <div class="service-head">
            <span class="service-num">/{String(service.data.order).padStart(2, '0')}</span>
            <span class="service-icon" set:html={iconMap[service.data.icon] ?? ''} />
          </div>
          <h2>{service.data.title}</h2>
          <p class="service-tagline">{service.data.tagline}</p>
          <p class="service-problem">{service.data.problem}</p>
          <ul class="service-outcomes">
            {service.data.outcomes.slice(0, 3).map(o => (
              <li>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {o}
              </li>
            ))}
          </ul>
          <a href={`/services/${service.data.slug}`} class="service-link">
            Learn more
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- Full-bleed neon CTA -->
  <section class="services-cta">
    <div class="container cta-inner fade">
      <div>
        <p class="eyebrow eyebrow-ink">Free audit</p>
        <h2>Not sure where to start?<br/>That's what the audit is for.</h2>
      </div>
      <a href="/contact" class="cta-btn">Book a Working Session</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .page-hero {
    padding: 9rem var(--pad-x) 5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-neon);
    display: block;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-grey);
    max-width: 52ch;
    margin-top: 1.5rem;
    line-height: 1.75;
  }

  /* ── Services grid ── */
  .services-section { padding: 0; }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-line);
  }

  .service-cell {
    background: var(--color-ink);
    padding: 3rem var(--pad-x);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .service-cell::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-neon);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }

  .service-cell:hover { background: var(--color-panel); }
  .service-cell:hover::before { transform: scaleX(1); }

  .service-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .service-num {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-neon);
    letter-spacing: 0.1em;
  }

  .service-icon { color: var(--color-dgrey); }

  .service-cell h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    max-width: none;
  }

  .service-tagline {
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-grey);
    margin-top: -0.5rem;
  }

  .service-problem {
    color: var(--color-grey);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .service-outcomes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .service-outcomes li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--color-white);
  }

  .service-outcomes svg { color: var(--color-neon); flex-shrink: 0; margin-top: 3px; }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-neon);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: gap 0.2s;
    margin-top: 0.5rem;
  }

  .service-link:hover { gap: 0.75rem; }

  /* ── CTA ── */
  .services-cta {
    background: var(--color-neon);
    padding: 5rem var(--pad-x);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .eyebrow-ink { color: rgba(10,10,10,0.5); }

  .cta-inner h2 {
    color: var(--color-ink);
    margin-top: 0.5rem;
    max-width: 30ch;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    background: var(--color-ink);
    color: var(--color-neon);
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    padding: 0.9rem 2rem;
    border-radius: var(--radius);
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .cta-btn:hover { opacity: 0.85; }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
