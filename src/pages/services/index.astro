---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const sorted = services.sort((a, b) => a.data.order - b.data.order);

const iconMap: Record<string, string> = {
  zap: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  brain: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  chart: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  users: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
};
---

<BaseLayout
  title="Services — Automation, AI Integration, Data & CRM | Bad Bhvr Systems"
  description="Process automation, applied AI, business intelligence, and CRM implementation for ambitious companies in Africa and EMEA. One connected operating system, not four disconnected projects."
>
  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>One operating system.<br />Not four disconnected projects.</h1>
      <p class="page-sub">
        Automation without data is guesswork. Data without automation is a report nobody acts on. AI without either is a toy. We build them as one connected system — which is why our clients' results compound instead of plateau.
      </p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="services-section">
    <div class="container">
      <div class="services-grid">
        {sorted.map((service, i) => (
          <article class="service-card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <div class="service-head">
              <span class="service-num">{String(service.data.order).padStart(2, '0')}</span>
              <span class="service-icon" set:html={iconMap[service.data.icon] ?? ''} />
            </div>
            <h2>{service.data.title}</h2>
            <p class="service-tagline">{service.data.tagline}</p>
            <p class="service-problem">{service.data.problem}</p>
            <ul class="service-outcomes">
              {service.data.outcomes.slice(0, 3).map(o => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {o}
                </li>
              ))}
            </ul>
            <a href={`/services/${service.data.slug}`} class="service-link">
              Learn more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta">
    <div class="container">
      <div class="cta-box reveal">
        <h2>Not sure where to start? That's what the audit is for.</h2>
        <a href="/contact" class="btn-accent">Book a Working Session</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: 10rem;
    padding-bottom: 5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 1rem;
  }

  .page-sub {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 560px;
    margin-top: 1.25rem;
    line-height: 1.75;
  }

  .services-section {
    padding-bottom: var(--spacing-section);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s, transform 0.3s;
  }

  .service-card:hover {
    border-color: rgba(232,83,26,0.4);
    transform: translateY(-3px);
  }

  .service-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .service-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .service-icon { color: var(--color-muted); }

  .service-card h2 { font-size: 1.5rem; }

  .service-tagline {
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-muted);
    margin-top: -0.25rem;
  }

  .service-problem {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .service-outcomes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .service-outcomes li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .service-outcomes svg { color: var(--color-accent); flex-shrink: 0; margin-top: 2px; }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: gap 0.2s;
  }

  .service-link:hover { gap: 0.7rem; }

  .services-cta {
    padding-bottom: var(--spacing-section);
  }

  .cta-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 3rem;
    text-align: center;
  }

  .cta-box h2 { margin-bottom: 1rem; }
  .cta-box p { color: var(--color-muted); margin-bottom: 2rem; max-width: 500px; margin-inline: auto; }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--color-accent);
    color: #0a0a0a;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s;
  }

  .btn-accent:hover { background: var(--color-accent-warm); transform: translateY(-1px); }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
