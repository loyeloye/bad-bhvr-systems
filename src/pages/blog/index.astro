---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/utils';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout
  title="Insights — AI, Automation & Data for Operators"
  description="Practical writing on automation, applied AI, CRM, and data for business operators in Africa and EMEA. No hype, no recycled thought-leadership."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Insights</p>
      <h1>Things we'd tell you<br/>over coffee.</h1>
      <p class="hero-sub">
        Practical writing for operators. What's working in automation and AI right now, what's overhyped, and what we're seeing inside real businesses from Lagos to Dubai.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="blog-section">
    {sorted.length === 0 ? (
      <div class="container empty-state fade">
        <p>Posts coming soon. Check back shortly.</p>
      </div>
    ) : (
      <div class="posts-grid">
        {sorted.map((post, i) => (
          <article class="post-cell fade" style={`transition-delay:${i * 0.08}s`}>
            <div class="post-top">
              <span class="post-category">{post.data.category}</span>
              <time datetime={post.data.publishDate.toISOString()} class="post-date">
                {formatDate(post.data.publishDate)}
              </time>
            </div>
            <h2>{post.data.title}</h2>
            <p class="post-excerpt">{post.data.excerpt}</p>
            <div class="post-tags">
              {post.data.tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}
            </div>
            <a href={`/blog/${post.id}`} class="post-link">
              Read post
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="blog-cta">
    <div class="container cta-inner fade">
      <div>
        <p class="eyebrow eyebrow-ink">Get it done</p>
        <h2>Read enough?<br/>Let's look at your business.</h2>
      </div>
      <a href="/contact" class="cta-btn">Book a Working Session</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .page-hero {
    padding: 9rem var(--pad-x) 5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-neon);
    display: block;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-grey);
    max-width: 50ch;
    margin-top: 1.5rem;
    line-height: 1.75;
  }

  /* ── Posts grid ── */
  .blog-section { padding: 0; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-line);
  }

  .post-cell {
    background: var(--color-ink);
    padding: 2.5rem var(--pad-x);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .post-cell::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-neon);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }

  .post-cell:hover { background: var(--color-panel); }
  .post-cell:hover::before { transform: scaleX(1); }

  .post-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-neon);
  }

  .post-date {
    font-size: 0.72rem;
    color: var(--color-dgrey);
  }

  .post-cell h2 {
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    line-height: 1.35;
    max-width: none;
  }

  .post-excerpt {
    font-size: 0.875rem;
    color: var(--color-grey);
    line-height: 1.7;
    flex: 1;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.68rem;
    border: 1px solid var(--color-line);
    color: var(--color-dgrey);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius);
  }

  .post-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-neon);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: gap 0.2s;
    margin-top: 0.25rem;
  }

  .post-link:hover { gap: 0.75rem; }

  .empty-state {
    padding: 5rem 0;
    color: var(--color-dgrey);
  }

  /* ── CTA ── */
  .blog-cta {
    background: var(--color-neon);
    padding: 5rem var(--pad-x);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .eyebrow-ink { color: rgba(10,10,10,0.5); }

  .cta-inner h2 {
    color: var(--color-ink);
    margin-top: 0.5rem;
    max-width: 28ch;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    background: var(--color-ink);
    color: var(--color-neon);
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    padding: 0.9rem 2rem;
    border-radius: var(--radius);
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .cta-btn:hover { opacity: 0.85; }

  @media (max-width: 900px) { .posts-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 580px) { .posts-grid { grid-template-columns: 1fr; } .cta-inner { flex-direction: column; align-items: flex-start; } }
</style>
