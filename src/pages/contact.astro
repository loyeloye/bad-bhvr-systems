---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import { SITE } from '../lib/utils';
---

<BaseLayout
  title="Contact — Book a Working Session | Bad Bhvr Systems"
  description="Book a working session with Bad Bhvr Systems. We'll look at one process in your business live and show you what it looks like automated."
>
  <section class="contact-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>No discovery-call theatre.<br />A working session.</h1>
      <p class="hero-sub">
        Tell us about your business and one thing that frustrates you about how it runs. We'll come to the call having actually thought about it — and we'll look at one process live. If we're not the right fit, we'll say so and point you somewhere useful.
      </p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container contact-layout">
      <!-- Form -->
      <div>
        <h2>Book a working session</h2>
        <p class="form-intro">Within one business day. Usually faster. For urgent: hit the WhatsApp button.</p>
        <div class="form-wrapper">
          <ContactForm />
        </div>
      </div>

      <!-- Info -->
      <aside class="contact-info">
        <div class="info-card">
          <h3>WhatsApp</h3>
          <a
            href={`${SITE.whatsappLink}?text=Hi%2C%20I%27d%20like%20to%20book%20a%20working%20session.`}
            class="contact-method wa"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            +234 810 698 1030
          </a>
          <p class="method-note">Fastest way to reach us. Tap to chat.</p>
        </div>

        <div class="info-card">
          <h3>Email</h3>
          <a href={`mailto:${SITE.email}`} class="contact-method email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            {SITE.email}
          </a>
          <p class="method-note">We respond within 1 business day.</p>
        </div>

        <div class="info-card">
          <h3>Book a Call</h3>
          <p class="method-note">Prefer to talk? Use the form above to request a call and we'll send you a booking link.</p>
        </div>

        <div class="info-card expectations">
          <h3>What to expect</h3>
          <ul>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              A real conversation, not a sales pitch
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Honest advice on where to start
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Clear next steps, whatever you decide
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              No obligation, no pressure
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 10rem;
    padding-bottom: 5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-muted);
    max-width: 580px;
    margin-top: 1.25rem;
    line-height: 1.75;
  }

  .contact-section {
    padding-bottom: var(--spacing-section);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 5rem;
    align-items: start;
  }

  .contact-layout h2 { margin-bottom: 0.5rem; }

  .form-intro {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .info-card h3 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .contact-method {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .contact-method.wa { color: #25D366; }
  .contact-method.wa:hover { color: #1da851; }
  .contact-method.email { color: var(--color-text); }
  .contact-method.email:hover { color: var(--color-accent); }

  .method-note {
    font-size: 0.8rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .expectations ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }

  .expectations li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .expectations li svg { color: var(--color-accent); flex-shrink: 0; }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
    .contact-info { order: -1; }
  }
</style>
