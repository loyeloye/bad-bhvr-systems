---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import { SITE } from '../lib/utils';
---

<BaseLayout
  title="Contact — Book a Working Session"
  description="Book a working session with Bad Bhvr Systems. We'll look at one process in your business live and show you what it looks like automated."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>No discovery-call theatre.<br/>A working session.</h1>
      <p class="hero-sub">
        Tell us about your business and one thing that frustrates you about how it runs. We'll come to the call having actually thought about it.
      </p>
    </div>
  </section>

  <!-- Contact layout -->
  <section class="contact-section">
    <div class="contact-grid">
      <!-- Form side -->
      <div class="form-side">
        <div class="form-head">
          <h2>Book a working session</h2>
          <p>Within one business day. Usually faster.</p>
        </div>
        <ContactForm />
      </div>

      <!-- Info side -->
      <aside class="info-side">
        <div class="info-row fade">
          <p class="info-label">WhatsApp</p>
          <a
            href={`${SITE.whatsappLink}?text=Hi%2C%20I%27d%20like%20to%20book%20a%20working%20session.`}
            class="info-link wa"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            +234 810 698 1030
          </a>
          <p class="info-note">Fastest way to reach us.</p>
        </div>

        <div class="info-row fade">
          <p class="info-label">Email</p>
          <a href={`mailto:${SITE.email}`} class="info-link email">{SITE.email}</a>
          <p class="info-note">We respond within 1 business day.</p>
        </div>

        <div class="info-row fade">
          <p class="info-label">What to expect</p>
          <ul class="expect-list">
            {[
              'A real conversation, not a sales pitch',
              'Honest advice on where to start',
              'Clear next steps, whatever you decide',
              'No obligation, no pressure',
            ].map(item => (
              <li>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="info-row neon-row fade">
          <p class="neon-stat">590%</p>
          <p class="neon-stat-label">Average ROI delivered on managed campaigns</p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .page-hero {
    padding: 9rem var(--pad-x) 5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-neon);
    display: block;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-grey);
    max-width: 48ch;
    margin-top: 1.5rem;
    line-height: 1.75;
  }

  /* ── Contact layout ── */
  .contact-section { padding: 0; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 1px;
    background: var(--color-line);
    min-height: 60vh;
  }

  /* Form side */
  .form-side {
    padding: 4rem var(--pad-x);
    background: var(--color-ink);
  }

  .form-head { margin-bottom: 2.5rem; }
  .form-head h2 { margin-bottom: 0.4rem; }
  .form-head p { color: var(--color-grey); font-size: 0.875rem; }

  /* Info side */
  .info-side {
    background: var(--color-panel);
    display: flex;
    flex-direction: column;
  }

  .info-row {
    padding: 2rem 2rem;
    border-bottom: 1px solid var(--color-line);
  }

  .info-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-dgrey);
    margin-bottom: 0.75rem;
  }

  .info-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    transition: opacity 0.2s;
  }

  .info-link:hover { opacity: 0.75; }
  .info-link.wa { color: #25D366; }
  .info-link.email { color: var(--color-white); }

  .info-note {
    font-size: 0.8rem;
    color: var(--color-dgrey);
    line-height: 1.5;
  }

  .expect-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .expect-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--color-grey);
  }

  .expect-list svg { color: var(--color-neon); flex-shrink: 0; margin-top: 2px; }

  /* Neon stat block */
  .neon-row {
    background: var(--color-neon);
    border-bottom: none;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .neon-stat {
    font-family: var(--font-head);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    color: var(--color-ink);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .neon-stat-label {
    font-size: 0.85rem;
    color: rgba(10,10,10,0.6);
    margin-top: 0.5rem;
    line-height: 1.4;
    max-width: 18ch;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .info-side { order: -1; }
    .neon-row { padding: 3rem 2rem; }
  }
</style>
