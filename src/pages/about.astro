---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';

const tools = [
  'n8n', 'Zoho CRM', 'Microsoft Dynamics 365', 'Meta Ads',
  'Google Analytics 4', 'Apify', 'OpenAI / GPT-4', 'Claude (Anthropic)',
  'Google Workspace', 'Looker Studio', 'Power BI', 'WhatsApp Business API',
];

const values = [
  {
    title: 'We audit before we recommend.',
    body: 'No proposal until we\'ve seen how your business actually works.',
  },
  {
    title: 'We build the business case first.',
    body: 'Every automation, integration, and dashboard comes with the math: hours saved, errors removed, revenue protected.',
  },
  {
    title: 'We build in your stack.',
    body: 'Tools you already pay for, accounts you own. No lock-in, no dependency on us.',
  },
  {
    title: 'We hand over the keys.',
    body: 'A system your team can\'t run without us is a system we built wrong.',
  },
];

const stats = [
  { num: '10+', label: 'Years inside real operations' },
  { num: '590%', label: 'ROI delivered for a client' },
  { num: '5+', label: 'Active partnerships' },
];
---

<BaseLayout
  title="About Bad Bhvr Systems — Why We Exist"
  description="Bad Bhvr Systems is an AI, automation, and data consultancy founded in Lagos. 10+ years of rebuilding how businesses operate, from Nigeria to the Gulf."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>Named after the<br/>way we work.</h1>
    </div>
  </section>

  <!-- Story + Stats -->
  <section class="story-section">
    <div class="container story-grid">
      <div class="story-text fade">
        <p>
          "Best practice" is what everyone else is already doing. Follow it and the ceiling is average.
        </p>
        <p>
          Bad Bhvr Systems was founded in Lagos on a different premise: the businesses that win the next decade are the ones willing to break their own habits — automate what's always been manual, hand work to AI that's always gone to overtime, and trust data over the loudest opinion in the room. In a traditional business culture, that's bad behaviour. It's also the only behaviour that compounds.
        </p>
        <p>
          We've spent 10+ years inside operations across Nigeria, the US, and the UK — enterprise IT firms, mobility companies, career services, consumer brands. Same pattern everywhere: good people held back by how the business runs. We fix the how.
        </p>
      </div>
      <div class="story-stats">
        {stats.map((s, i) => (
          <div class="stat-row fade" style={`transition-delay:${i * 0.12}s`}>
            <span class="stat-num">{s.num}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values hairline grid -->
  <section class="values-section">
    <div class="container">
      <div class="section-head fade">
        <p class="eyebrow">How we work</p>
        <h2>Strong opinions,<br/>measurable results.</h2>
      </div>
      <div class="values-grid">
        {values.map((v, i) => (
          <div class="value-cell fade" style={`transition-delay:${i * 0.1}s`}>
            <span class="value-num">/{String(i + 1).padStart(2, '0')}</span>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section class="tools-section">
    <div class="container">
      <div class="section-head fade">
        <p class="eyebrow">The toolbox</p>
        <h2>Platform-agnostic.<br/>We recommend what fits.</h2>
      </div>
      <div class="tools-wrap fade">
        {tools.map(t => <span class="tool-tag">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- CTA neon band -->
  <section class="about-cta">
    <div class="container cta-grid">
      <div class="cta-copy">
        <p class="eyebrow eyebrow-ink">Working session</p>
        <h2>If your business runs on heroics and memory, we should talk.</h2>
        <p>We'll look at one process in your business live — and tell you honestly what we'd change.</p>
      </div>
      <div class="cta-form">
        <ContactForm compact={true} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .page-hero {
    padding: 9rem var(--pad-x) 5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-neon);
    display: block;
    margin-bottom: 1.5rem;
  }

  /* ── Story ── */
  .story-section {
    padding: 6rem var(--pad-x);
    border-bottom: 1px solid var(--color-line);
    background: var(--color-panel);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 6rem;
    align-items: start;
  }

  .story-text p {
    color: var(--color-grey);
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }

  .story-stats { display: flex; flex-direction: column; gap: 0; }

  .stat-row {
    border-top: 1px solid var(--color-line);
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .stat-row:last-child { border-bottom: 1px solid var(--color-line); }

  .stat-num {
    font-family: var(--font-head);
    font-size: 2.8rem;
    font-weight: 800;
    color: var(--color-neon);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-grey);
    line-height: 1.4;
  }

  /* ── Values ── */
  .values-section {
    padding: 6rem var(--pad-x);
    border-bottom: 1px solid var(--color-line);
  }

  .section-head {
    margin-bottom: 3.5rem;
  }

  .section-head h2 { max-width: 20ch; }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-line);
  }

  .value-cell {
    background: var(--color-ink);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .value-cell::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-neon);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }

  .value-cell:hover { background: var(--color-panel); }
  .value-cell:hover::before { transform: scaleX(1); }

  .value-num {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-neon);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 1.25rem;
  }

  .value-cell h3 {
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .value-cell p {
    color: var(--color-grey);
    font-size: 0.875rem;
    line-height: 1.75;
  }

  /* ── Tools ── */
  .tools-section {
    padding: 6rem var(--pad-x);
    background: var(--color-panel);
    border-bottom: 1px solid var(--color-line);
  }

  .tools-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tool-tag {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.45rem 1rem;
    border: 1px solid var(--color-line);
    color: var(--color-grey);
    border-radius: var(--radius);
    transition: border-color 0.2s, color 0.2s;
    cursor: default;
  }

  .tool-tag:hover { border-color: var(--color-neon); color: var(--color-white); }

  /* ── CTA ── */
  .about-cta {
    background: var(--color-neon);
    padding: 6rem var(--pad-x);
  }

  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .cta-copy .eyebrow-ink {
    color: rgba(10,10,10,0.5);
  }

  .cta-copy h2 {
    color: var(--color-ink);
    margin-bottom: 1rem;
  }

  .cta-copy p {
    color: rgba(10,10,10,0.7);
    font-size: 1rem;
    line-height: 1.75;
  }

  /* Override form styles inside neon band */
  .cta-form :global(label) { color: var(--color-ink) !important; }
  .cta-form :global(input),
  .cta-form :global(select),
  .cta-form :global(textarea) {
    background: rgba(10,10,10,0.08) !important;
    border-color: rgba(10,10,10,0.2) !important;
    color: var(--color-ink) !important;
  }
  .cta-form :global(input::placeholder),
  .cta-form :global(textarea::placeholder) { color: rgba(10,10,10,0.4) !important; }
  .cta-form :global(.submit-btn) {
    background: var(--color-ink) !important;
    color: var(--color-neon) !important;
  }
  .cta-form :global(.form-note) { color: rgba(10,10,10,0.5) !important; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .story-grid { grid-template-columns: 1fr; gap: 3rem; }
    .values-grid { grid-template-columns: 1fr; }
    .cta-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
