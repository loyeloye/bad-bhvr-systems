---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const caseStudies = await getCollection('caseStudies');
  return caseStudies.map(cs => ({
    params: { slug: cs.id },
    props: { study: cs },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);
const d = study.data;
---

<BaseLayout
  title={d.metaTitle ?? `${d.client}: ${d.title} | Bad Bhvr Systems`}
  description={d.metaDescription ?? d.problem}
  article={true}
>
  <article>
    <header class="cs-header">
      <div class="container">
        <a href="/case-studies" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          All Case Studies
        </a>

        <div class="cs-meta">
          <span class="cs-industry">{d.industry}</span>
          <time datetime={d.publishDate.toISOString()}>{formatDate(d.publishDate)}</time>
        </div>

        <h1>{d.client}</h1>
        <p class="cs-title-sub">{d.title}</p>

        <div class="cs-hero-metric">
          <span class="metric-num">{d.resultMetric}</span>
          <span class="metric-label">{d.result}</span>
        </div>

        <div class="cs-tools">
          {d.tools.map(t => <span class="tool-tag">{t}</span>)}
        </div>
      </div>
    </header>

    <div class="cs-body">
      <div class="container cs-layout">
        <div class="cs-content">
          <Content />
        </div>
        <aside class="cs-sidebar">
          <div class="sidebar-card">
            <h3>The Result</h3>
            <div class="result-big">
              <span class="metric-num">{d.resultMetric}</span>
              <span class="metric-label">{d.result}</span>
            </div>
          </div>
          <div class="sidebar-card">
            <h3>Tools Used</h3>
            <div class="tools-list">
              {d.tools.map(t => <span class="tool-tag">{t}</span>)}
            </div>
          </div>
          <div class="sidebar-cta">
            <p>Want results like this?</p>
            <a href="/contact" class="btn-accent">Book a Free Audit</a>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .cs-header {
    padding-top: 9rem;
    padding-bottom: 4rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--color-text); }

  .cs-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .cs-header h1 { font-size: clamp(2.5rem, 6vw, 4rem); }

  .cs-title-sub {
    font-size: 1.2rem;
    color: var(--color-muted);
    margin-top: 0.75rem;
    max-width: 600px;
  }

  .cs-hero-metric {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-top: 2.5rem;
    padding: 1.5rem 2rem;
    background: rgba(232,83,26,0.08);
    border: 1px solid rgba(232,83,26,0.2);
    border-radius: var(--radius-md);
    display: inline-flex;
  }

  .metric-num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .metric-label { color: var(--color-muted); font-size: 1rem; }

  .cs-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.5rem;
  }

  .tool-tag {
    font-size: 0.75rem;
    background: var(--color-surface-2);
    color: var(--color-muted);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }

  .cs-body {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .cs-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: start;
  }

  .cs-content {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.85;
  }

  .cs-content :global(h2) {
    font-size: 1.4rem;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .cs-content :global(p) { margin-bottom: 1rem; }

  .cs-content :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .cs-content :global(li) { margin-bottom: 0.4rem; }

  .cs-content :global(strong) { color: var(--color-text); }

  .sidebar-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .sidebar-card h3 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .result-big {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .result-big .metric-num { font-size: 2.5rem; }
  .result-big .metric-label { font-size: 0.875rem; }

  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .sidebar-cta {
    background: rgba(232,83,26,0.06);
    border: 1px solid rgba(232,83,26,0.2);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-cta p { font-weight: 600; color: var(--color-text); font-size: 0.9rem; }

  .btn-accent {
    display: inline-flex;
    background: var(--color-accent);
    color: #0a0a0a;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
    text-align: center;
    justify-content: center;
  }

  .btn-accent:hover { background: var(--color-accent-warm); }

  @media (max-width: 900px) {
    .cs-layout { grid-template-columns: 1fr; }
    .cs-sidebar { order: -1; }
  }
</style>
