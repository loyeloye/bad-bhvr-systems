---
// Three.js globe with danfo bus — lazy-loaded, tab-aware, reduced-motion safe
---

<div class="hero-viz" aria-hidden="true">
  <div id="globeWrap" style="width:100%;aspect-ratio:1/1"></div>
</div>

<style>
  .hero-viz {
    position: absolute;
    right: 3vw;
    top: 50%;
    transform: translateY(-50%);
    width: min(42vw, 580px);
    pointer-events: none;
    z-index: 0;
  }

  #globeWrap {
    -webkit-mask-image: radial-gradient(circle at 50% 50%, #000 52%, transparent 74%);
    mask-image: radial-gradient(circle at 50% 50%, #000 52%, transparent 74%);
  }

  @media (max-width: 1100px) {
    .hero-viz { display: none; }
  }
</style>

<script>
  const initGlobe = async () => {
    const wrap = document.getElementById('globeWrap');
    if (!wrap) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const THREE = await import('three');

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 20);
    camera.position.set(0, 0.3, 1.92);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    wrap.appendChild(renderer.domElement);

    function resize() {
      const s = wrap.clientWidth;
      renderer.setSize(s, s);
      camera.aspect = 1;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    scene.add(new THREE.AmbientLight(0xffffff, 0.75));
    const dl = new THREE.DirectionalLight(0xffffff, 0.9);
    dl.position.set(2, 3, 4);
    scene.add(dl);

    const earth = new THREE.Group();
    scene.add(earth);

    earth.add(new THREE.Mesh(
      new THREE.SphereGeometry(0.992, 64, 64),
      new THREE.MeshStandardMaterial({ color: 0x0E0E0E, roughness: 0.95, metalness: 0 })
    ));

    scene.add(new THREE.Mesh(
      new THREE.SphereGeometry(1.015, 64, 64),
      new THREE.MeshBasicMaterial({ color: 0xE8FF2A, transparent: true, opacity: 0.025, side: THREE.BackSide })
    ));

    const ll = (lat: number, lon: number, r: number) => {
      const p = (lat * Math.PI) / 180;
      const l = (lon * Math.PI) / 180;
      return new THREE.Vector3(r * Math.cos(p) * Math.cos(l), r * Math.sin(p), -r * Math.cos(p) * Math.sin(l));
    };

    const NEON = 0xE8FF2A;
    const hiMat = new THREE.LineBasicMaterial({ color: NEON });
    const baseMat = new THREE.LineBasicMaterial({ color: 0x3C3C38, transparent: true, opacity: 0.6 });
    const fillMat = new THREE.MeshBasicMaterial({ color: NEON, transparent: true, opacity: 0.14, side: THREE.DoubleSide, depthWrite: false });

    const HI = new Set(['NGA', 'GHA', 'RWA', 'KEN', 'ZAF', 'ARE']);

    function addRing(coords: number[][], r: number, mat: THREE.LineBasicMaterial) {
      const pts = coords.map((c: number[]) => ll(c[1], c[0], r));
      earth.add(new THREE.LineLoop(new THREE.BufferGeometry().setFromPoints(pts), mat));
    }

    fetch('/world.geo.json')
      .then(r => r.json())
      .then((geo: any) => {
        geo.features.forEach((f: any) => {
          const hi = HI.has(f.id);
          const polys = f.geometry.type === 'Polygon' ? [f.geometry.coordinates] : f.geometry.coordinates;
          polys.forEach((poly: any) => {
            poly.forEach((rg: number[][], ri: number) => {
              if (rg.length < 4) return;
              const step = hi ? 1 : (Math.ceil(rg.length / 200) || 1);
              addRing(rg.filter((_: any, i: number) => i % step === 0), hi ? 1.004 : 1.001, hi ? hiMat : baseMat);
              if (hi && ri === 0) {
                const shape = new THREE.Shape(rg.map((c: number[]) => new THREE.Vector2(c[0], c[1])));
                const g = new THREE.ShapeGeometry(shape);
                const pos = g.attributes.position;
                for (let i = 0; i < pos.count; i++) {
                  const v = ll(pos.getY(i), pos.getX(i), 1.0025);
                  pos.setXYZ(i, v.x, v.y, v.z);
                }
                g.computeVertexNormals();
                earth.add(new THREE.Mesh(g, fillMat));
              }
            });
          });
        });
      })
      .catch(() => {});

    const stops: [string, number, number][] = [
      ['LAGOS', 6.45, 3.40],
      ['ACCRA', 5.60, -0.19],
      ['KIGALI', -1.95, 30.06],
      ['NAIROBI', -1.29, 36.82],
      ['JOHANNESBURG', -26.20, 28.05],
      ['ABU DHABI', 24.45, 54.38],
      ['DUBAI', 25.20, 55.27],
    ];

    const stopVecs = stops.map(s => ll(s[1], s[2], 1));

    const dotMat = new THREE.MeshBasicMaterial({ color: NEON });
    stops.forEach((_, i) => {
      const m = new THREE.Mesh(new THREE.SphereGeometry(0.013, 12, 12), dotMat);
      m.position.copy(stopVecs[i].clone().multiplyScalar(1.006));
      earth.add(m);
    });

    // Danfo bus — always yellow, never themed
    const bus = new THREE.Group();
    const yellow = new THREE.MeshStandardMaterial({ color: 0xF7C600, roughness: 0.5 });
    const black = new THREE.MeshStandardMaterial({ color: 0x0A0A0A, roughness: 0.7 });
    const glass = new THREE.MeshStandardMaterial({ color: 0x0E161A, roughness: 0.15, metalness: 0.6 });

    const body = new THREE.Mesh(new THREE.BoxGeometry(0.24, 0.105, 0.105), yellow);
    body.position.set(0, 0.0775, 0);
    bus.add(body);

    const ws = new THREE.Mesh(new THREE.BoxGeometry(0.005, 0.046, 0.09), glass);
    ws.position.set(0.1205, 0.103, 0);
    bus.add(ws);

    const grille = new THREE.Mesh(new THREE.BoxGeometry(0.005, 0.02, 0.07), black);
    grille.position.set(0.1205, 0.052, 0);
    bus.add(grille);

    ([0.0345, -0.0345] as number[]).forEach(z => {
      const hl = new THREE.Mesh(new THREE.SphereGeometry(0.009, 10, 10), new THREE.MeshBasicMaterial({ color: 0xFFFDE0 }));
      hl.position.set(0.122, 0.072, z);
      bus.add(hl);
    });

    const bf = new THREE.Mesh(new THREE.BoxGeometry(0.014, 0.016, 0.11), black);
    bf.position.set(0.122, 0.03, 0);
    bus.add(bf);
    const bb = bf.clone();
    bb.position.x = -0.122;
    bus.add(bb);

    ([-0.034, 0.034] as number[]).forEach(z => {
      const tl = new THREE.Mesh(new THREE.SphereGeometry(0.006, 8, 8), new THREE.MeshBasicMaterial({ color: 0xFF4433 }));
      tl.position.set(-0.124, 0.07, z);
      bus.add(tl);
    });

    [-0.0535, 0.0535].forEach(z => {
      const trim = new THREE.Mesh(new THREE.BoxGeometry(0.21, 0.042, 0.003), black);
      trim.position.set(-0.002, 0.106, z);
      bus.add(trim);
      const band = new THREE.Mesh(new THREE.BoxGeometry(0.2, 0.034, 0.004), glass);
      band.position.set(-0.002, 0.106, z > 0 ? z + 0.002 : z - 0.002);
      bus.add(band);
    });

    const rw = new THREE.Mesh(new THREE.BoxGeometry(0.005, 0.038, 0.078), glass);
    rw.position.set(-0.1205, 0.105, 0);
    bus.add(rw);

    const roofM = new THREE.Mesh(new THREE.BoxGeometry(0.235, 0.007, 0.1), yellow);
    roofM.position.set(0, 0.133, 0);
    bus.add(roofM);

    ([[0.078, 0.056], [0.078, -0.056], [-0.078, 0.056], [-0.078, -0.056]] as [number, number][]).forEach(([x, z]) => {
      const w = new THREE.Mesh(new THREE.CylinderGeometry(0.027, 0.027, 0.016, 20), black);
      w.rotation.x = Math.PI / 2;
      w.position.set(x, 0.027, z);
      bus.add(w);
      const rim2 = new THREE.Mesh(
        new THREE.CylinderGeometry(0.016, 0.016, 0.017, 16),
        new THREE.MeshStandardMaterial({ color: 0xB8B8B8, roughness: 0.4, metalness: 0.5 })
      );
      rim2.rotation.x = Math.PI / 2;
      rim2.position.set(x, 0.027, z);
      bus.add(rim2);
    });

    bus.scale.setScalar(0.78);
    earth.add(bus);

    const slerpV = (a: THREE.Vector3, b: THREE.Vector3, t: number) => {
      const th = a.angleTo(b);
      if (th < 1e-6) return a.clone();
      const s = Math.sin(th);
      return a.clone().multiplyScalar(Math.sin((1 - t) * th) / s)
             .add(b.clone().multiplyScalar(Math.sin(t * th) / s));
    };

    const DWELL = 2.2, TRAVEL = 3.0, LEG = DWELL + TRAVEL, CYCLE = LEG * stops.length;
    const ease = (t: number) => t * t * (3 - 2 * t);
    const f = new THREE.Vector3(0, 0.18, 1).normalize();
    const q = new THREE.Quaternion();
    const up = new THREE.Vector3(), fw = new THREE.Vector3(), sd = new THREE.Vector3();
    const m4 = new THREE.Matrix4();
    let start = performance.now();

    const tick = (now: number) => {
      requestAnimationFrame(tick);
      if (document.hidden) return;

      const t = ((now - start) / 1000) % CYCLE;
      const leg = Math.floor(t / LEG);
      const ph = t % LEG;
      const a = stopVecs[leg];
      const b = stopVecs[(leg + 1) % stopVecs.length];
      const tt = ph < DWELL ? 0 : ease((ph - DWELL) / TRAVEL);
      const pos = slerpV(a, b, tt);
      const ahead = slerpV(a, b, Math.min(tt + 0.012, 1));

      up.copy(pos).normalize();
      fw.copy(ahead).sub(pos);
      fw.addScaledVector(up, -fw.dot(up));
      if (fw.lengthSq() < 1e-10) fw.copy(b).sub(a).addScaledVector(up, -b.clone().sub(a).dot(up));
      fw.normalize();
      sd.crossVectors(fw, up).normalize();
      m4.makeBasis(fw, up, sd);
      bus.quaternion.setFromRotationMatrix(m4);
      bus.position.copy(pos).multiplyScalar(1.004);

      q.setFromUnitVectors(pos.clone().normalize(), f);
      earth.quaternion.slerp(q, 0.045);

      renderer.render(scene, camera);
    };

    requestAnimationFrame(tick);
  };

  if ('requestIdleCallback' in window) {
    (window as any).requestIdleCallback(initGlobe, { timeout: 2000 });
  } else {
    setTimeout(initGlobe, 200);
  }
</script>
