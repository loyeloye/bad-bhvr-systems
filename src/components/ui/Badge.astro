---
interface Props {
  variant?: 'accent' | 'muted' | 'green';
}
const { variant = 'accent' } = Astro.props;
---
<span class:list={['badge', `badge-${variant}`]}><slot /></span>

<style>
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .badge-accent { background: rgba(232,83,26,0.15); color: var(--color-accent); }
  .badge-muted { background: var(--color-surface-2); color: var(--color-muted); }
  .badge-green { background: rgba(37,211,102,0.12); color: #25D366; }
</style>
