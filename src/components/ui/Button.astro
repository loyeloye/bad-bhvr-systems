---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'wa';
  size?: 'sm' | 'md' | 'lg';
  target?: string;
  rel?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  target,
  rel,
  class: className,
  type = 'button',
  disabled,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  target={target}
  rel={rel}
  type={!href ? type : undefined}
  disabled={disabled}
  class:list={['btn', `btn-${variant}`, `btn-${size}`, className]}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s, box-shadow 0.2s;
    white-space: nowrap;
  }

  .btn:hover { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  /* Sizes */
  .btn-sm { font-size: 0.8rem; padding: 0.4rem 0.9rem; }
  .btn-md { font-size: 0.9rem; padding: 0.65rem 1.4rem; }
  .btn-lg { font-size: 1rem; padding: 0.85rem 1.9rem; }

  /* Variants */
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-white);
  }
  .btn-primary:hover {
    background: var(--color-accent-warm);
    box-shadow: 0 4px 20px rgba(232, 83, 26, 0.35);
  }

  .btn-secondary {
    background: var(--color-surface-2);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-ghost:hover {
    background: var(--color-surface-2);
  }

  .btn-wa {
    background: #25D366;
    color: white;
  }
  .btn-wa:hover {
    background: #20ba58;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.3);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }
</style>
